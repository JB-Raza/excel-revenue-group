rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Bookable slots — generated by the admin (Cloud/GitHub Action).
    match /Available_Slots/{slotId} {
      allow read: if true;

      // Clients never create or delete slots (admin SDK only).
      allow create, delete: if false;

      // Clients may only flip an open slot to booked (isAvailable true -> false).
      // Date/time fields must stay identical so a slot can't be rewritten.
      allow update: if resource.data.isAvailable == true
        && request.resource.data.isAvailable == false
        && request.resource.data.date == resource.data.date
        && request.resource.data.timeFrom == resource.data.timeFrom
        && request.resource.data.timeTo == resource.data.timeTo;
    }

    // Booking records — contact details are private (no client reads).
    match /Bookings/{bookingId} {
      allow read, update, delete: if false;

      allow create: if request.resource.data.status == "confirmed"
        && request.resource.data.slotId is string
        && request.resource.data.date is string
        && request.resource.data.userEmail is string
        && request.resource.data.userEmail.size() > 3;
    }
  }
}
