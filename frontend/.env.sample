# Web3Forms — create key at https://web3forms.com (submissions email = verified dashboard email)
NEXT_PUBLIC_WEB3FORMS_KEY=your_access_key_here

# Contact info shown on the site
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
NEXT_PUBLIC_CONTACT_PHONE=03211488052
# Digits with country code — tel: is added automatically if omitted
NEXT_PUBLIC_CONTACT_PHONE_HREF=+923211488052
NEXT_PUBLIC_CONTACT_WHATSAPP=923211488052

# Address text shown on contact page / footer
NEXT_PUBLIC_CONTACT_ADDRESS=123 Main St, City, State 12345

# map embed url

# map embed url
NEXT_PUBLIC_CONTACT_ADDRESS=location_of_the_business_as_Lahore_,_pakistan
NEXT_PUBLIC_CONTACT_MAP_EMBED_URL=embed_url_from_google_maps


# Firebase (Firestore booking) — from Firebase Console → Project settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here